# EPC Intelligence Core — Example Environment Variables
# Copy this to .env for local development (never commit .env with real keys)

# ── Required ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Storage Paths (use /data/* on Render, ./data/* locally) ──────────────────────
CHROMA_DB_PATH=./data/chroma_db
UPLOAD_DIR=./data/uploads
STANDARDS_DIR=./data/standards
TEST_RECORDS_DIR=./data/test_records

# ── Database ─────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./epc.db

# ── Embedding ────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── RAG Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=5
