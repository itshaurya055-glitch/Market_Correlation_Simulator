# EPC Intelligence Core — .gitignore

# ── Python ──────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Environment ─────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Data / Runtime (use Render's persistent disk instead) ───────────────────────
data/chroma_db/
data/uploads/
*.db
*.sqlite

# ── IDE ─────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Testing ─────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── OS ──────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
